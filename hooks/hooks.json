{
  "description": "Inject the source-attribution policy each turn (UserPromptSubmit) and verify filesystem-checkable citations both when Claude asks the user a question (PreToolUse/AskUserQuestion — Stop does not fire there) and when Claude finishes (Stop).",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/source-attribution-inject.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/grounding-verifier.py"]
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/grounding-verifier.py"]
          }
        ]
      }
    ]
  }
}
